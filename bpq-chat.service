[Unit]
Description=BPQ Dashboard - Chat Server Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
ExecStart=/usr/bin/python3 /var/www/bpqdash/scripts/bpq-chat-daemon.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bpq-chat

[Install]
WantedBy=multi-user.target
