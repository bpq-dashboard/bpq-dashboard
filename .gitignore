# BPQ Dashboard — files that should never be committed

# Configuration (contains passwords)
config.php
nws-config.php
bbs-config.php

# Runtime / generated data
cache/*
!cache/.gitkeep
data/messages/
data/stations/
data/.bbs_auth
data/backups/
wx/*
!wx/.gitkeep

# Logs
logs/*
!logs/.gitkeep
*.log
connect-watchdog.log
prop-scheduler.log
storm-monitor.log

# Development notes
SESSION-JOURNAL.txt
watchdog-state.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
