<?php
/**
 * BBS Messages Configuration
 * 
 * Copy this file to bbs-config.php and edit the values below.
 * 
 * IMPORTANT: The 'bbs_alias' setting is the command used to connect from 
 * your BPQ node to the BBS application. To find this:
 * 
 * 1. Connect to your node via telnet
 * 2. Look at the list of available applications
 * 3. Find the BBS entry (e.g., "AUGBBS:K1AJD-7" means alias is "AUGBBS")
 * 
 * Common aliases: BBS, MYBBS, LOCALBBS, or a custom name like AUGBBS
 */

$config = [
    // BBS Connection Settings
    'bbs_host' => 'localhost',      // BBS telnet host (usually localhost)
    'bbs_port' => 8010,             // BBS telnet port (check your BPQ config)
    'bbs_user' => 'YOURCALL',       // Your callsign (for login)
    'bbs_pass' => 'yourpassword',   // Your BBS password
    'bbs_alias' => 'BBS',           // BBS application alias (see note above)
    
    // Timeouts
    'timeout' => 30,                // Connection timeout in seconds
    
    // Display Settings
    'default_count' => 20,          // Default number of messages to show
    'max_count' => 100,             // Maximum messages allowed per request
    
    // Logging (for troubleshooting)
    'log_file' => __DIR__ . '/logs/bbs-messages.log'  // Log file path
];
